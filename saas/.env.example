# Supabase — copie tudo da MESMA página: Project Settings → API (URL + anon + service_role do mesmo projeto)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Opcional: URL pública do app (convites por e-mail). Se vazio, usa o host do request.
# NEXT_PUBLIC_SITE_URL=https://seu-dominio.com

# Auth → URL configuration → Redirect URLs (convite e confirmação de e-mail). Inclua a porta que você usa:
# http://localhost:3000/auth/callback**
# http://localhost:3001/auth/callback**
#
# Equipe: em Configurações → Equipe o gestor pode criar usuário com senha (sem depender de e-mail).
# “Vincular conta existente” usa magic link opcional — aí Redirect URLs (acima) precisam estar corretas.

# Datajud (CNJ) — só no servidor; chave pública em:
# https://datajud-wiki.cnj.jus.br/api-publica/acesso/
DATAJUD_API_KEY=

# Service role (secret longa, NÃO use a "anon" / public): convites equipe, cron, webhooks. Só no servidor.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Lembretes de prazos por e-mail (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Cron (Vercel: mesmo valor em Project Settings → Env). GET/POST /api/cron/lembretes-prazos
# Header: Authorization: Bearer CRON_SECRET
CRON_SECRET=

# WhatsApp — Z-API (https://developer.z-api.io). Lembretes usam o telefone do escritório em Configurações.
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Google Calendar (OAuth) — credenciais em Google Cloud Console → APIs → OAuth 2.0
# Libere o redirect: {SITE_URL}/api/google-calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Assinatura eletrônica — ZapSign (https://app.zapsign.com.br)
ZAPSIGN_API_KEY=

# Webhook ZapSign — URL pública: /api/webhooks/zapsign?token=SEU_SEGREDO (o mesmo valor aqui)
ZAPSIGN_WEBHOOK_SECRET=
